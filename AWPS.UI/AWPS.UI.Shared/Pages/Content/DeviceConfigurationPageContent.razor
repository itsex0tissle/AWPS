@inject IHttpClientFactory HttpFactory

@if (base.RendererInfo.IsInteractive is false)
{
    <div class="flex h-96 items-center justify-center">
        <div class="text-center">
            <div class="mx-auto h-16 w-16 animate-spin rounded-full border-b-2 border-blue-600"></div>
            <p class="mt-4 text-lg text-gray-600">Loading page...</p>
        </div>
    </div>
}
else
{
    <div class="mx-auto max-w-xl cursor-default space-y-6 p-6 select-none">

        <div>
            <h1 class="text-3xl font-bold text-gray-800">
                Device Configuration
            </h1>

            <p class="mt-1 text-sm text-gray-500">
                Connect the device to your home Wi-Fi network.
            </p>
        </div>

        <div class="rounded-xl border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
            ⚠️ After connecting the device to your Wi-Fi, you will need to reconnect
            your computer or phone to your normal network before leaving this page.
        </div>

        @if (!DeviceReachable)
        {
            <div class="rounded-xl border border-red-200 bg-red-50 p-5">

                <h3 class="font-semibold text-red-700">
                    Device not reachable
                </h3>

                <p class="mt-1 text-sm text-red-600">
                    Please connect to the Wi-Fi access point created by the device.
                </p>

                <button class="mt-4 flex cursor-pointer items-center gap-2 rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-red-700 active:scale-95 active:bg-red-800 disabled:cursor-default disabled:bg-red-300"
                        disabled="@CheckingConnection"
                        @onclick="CheckDeviceConnection">

                    @if (CheckingConnection)
                    {
                        <span class="h-4 w-4 animate-spin rounded-full border-2 border-white border-b-transparent"></span>
                        <span>Checking connection...</span>
                    }
                    else
                    {
                        <span>Check connection</span>
                    }

                </button>

            </div>
        }

        <fieldset disabled="@DisableUi" class="space-y-6 disabled:opacity-60">

            <div class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-200">

                <div class="mb-4 flex items-center justify-between">

                    <h2 class="text-lg font-semibold text-gray-800">
                        Wi-Fi Status
                    </h2>

                    <button class="flex cursor-pointer items-center gap-2 rounded-md bg-gray-200 px-3 py-1 text-sm transition hover:bg-gray-300 disabled:cursor-default disabled:bg-gray-100 not-disabled:active:scale-95 not-disabled:active:bg-gray-400"
                            disabled="@RefreshingStatus"
                            @onclick="RefreshStatus">

                        @if (RefreshingStatus)
                        {
                            <span class="h-3 w-3 animate-spin rounded-full border-2 border-gray-600 border-b-transparent"></span>
                        }

                        <span>Refresh</span>

                    </button>

                </div>

                @if (WifiStatus is null)
                {
                    <p class="text-sm text-gray-500">Loading status...</p>
                }
                else
                {
                    <div class="space-y-2 text-sm">

                        <div class="flex items-center gap-2">

                            <span>Status:</span>

                            @if (WifiStatus.Connected)
                            {
                                <span class="rounded-full bg-green-100 px-2 py-1 text-xs font-semibold text-green-700">
                                    Connected
                                </span>
                            }
                            else
                            {
                                <span class="rounded-full bg-red-100 px-2 py-1 text-xs font-semibold text-red-700">
                                    Disconnected
                                </span>
                            }

                        </div>

                        <div>
                            <span class="text-gray-600">SSID:</span>
                            <span class="ml-1 cursor-text font-mono text-gray-800 select-text">
                                @WifiStatus.SSID
                            </span>
                        </div>

                    </div>
                }

            </div>


            <div class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-200">

                <h2 class="mb-4 text-lg font-semibold text-gray-800">
                    Configure Wi-Fi
                </h2>

                <div class="space-y-4">

                    <div>
                        <label class="mb-1 block text-sm font-medium text-gray-700">
                            Network name (SSID)
                        </label>

                        <input class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm not-disabled:cursor-text focus:border-blue-500 focus:ring-1 focus:ring-blue-500 focus:outline-none"
                               placeholder="Your Wi-Fi name"
                               @bind="Ssid" />

                        <p class="mt-1 text-xs text-gray-500">
                            Enter the Wi-Fi network the device should connect to.
                        </p>
                    </div>


                    <div>
                        <label class="mb-1 block text-sm font-medium text-gray-700">
                            Password
                        </label>

                        <input type="password"
                               class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm not-disabled:cursor-text focus:border-blue-500 focus:ring-1 focus:ring-blue-500 focus:outline-none"
                               placeholder="Wi-Fi password"
                               @bind="Password" />
                    </div>


                    <button class="flex w-full cursor-pointer items-center justify-center gap-2 rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-blue-700 disabled:cursor-default disabled:bg-blue-300 not-disabled:active:scale-95 not-disabled:active:bg-blue-800"
                            disabled="@PostingWifi"
                            @onclick="SubmitWifi">

                        @if (PostingWifi)
                        {
                            <span class="h-4 w-4 animate-spin rounded-full border-2 border-white border-b-transparent"></span>
                            <span>Connecting device...</span>
                        }
                        else
                        {
                            <span>Connect Device</span>
                        }

                    </button>

                </div>


                @if (PostResult is not null)
                {
                    <div class="mt-4 text-sm">

                        @if (PostResult.Success)
                        {
                            <div class="rounded-lg border border-green-200 bg-green-50 p-3 text-green-700">
                                @PostResult.Description
                            </div>
                        }
                        else
                        {
                            <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-red-700">
                                @PostResult.Description
                            </div>
                        }

                    </div>
                }

            </div>

        </fieldset>

    </div>
}

@code
{
    private const string GetPingUrl = "http://192.168.4.1";
    private const string GetWifiStatusUrl = "http://192.168.4.1/wifi";
    private const string PostWifiUrl = "http://192.168.4.1/wifi";

    private GetWifiStatusResponseRecord? WifiStatus;
    private PostWifiResponseRecord? PostResult;

    private string Ssid = "";
    private string Password = "";

    private bool DeviceReachable = false;
    private bool CheckingConnection = false;
    private bool PostingWifi = false;
    private bool RefreshingStatus = false;

    private bool DisableUi => !DeviceReachable || CheckingConnection || PostingWifi;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && base.RendererInfo.IsInteractive)
        {
            await CheckDeviceConnection();
        }
    }

    private async Task CheckDeviceConnection()
    {
        CheckingConnection = true;

        try
        {
            HttpClient client = HttpFactory.CreateClient();

            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(3));

            HttpResponseMessage response =
                await client.GetAsync(GetPingUrl, cts.Token);

            DeviceReachable = response.IsSuccessStatusCode;
        }
        catch
        {
            PostResult = null;
            DeviceReachable = false;
        }

        CheckingConnection = false;

        if (DeviceReachable)
        {
            await RefreshStatus();
        }

        StateHasChanged();
    }

    private async Task RefreshStatus()
    {
        RefreshingStatus = true;
        StateHasChanged();

        try
        {
            HttpClient client = HttpFactory.CreateClient();

            byte[] data =
                await client.GetByteArrayAsync(GetWifiStatusUrl);

            GetWifiStatusResponseRecord record = new();

            record.Deserialize(data);

            WifiStatus = record;
        }
        catch
        {
            PostResult = null;
            DeviceReachable = false;
        }

        RefreshingStatus = false;
        StateHasChanged();
    }

    private async Task SubmitWifi()
    {
        PostingWifi = true;
        PostResult = null;
        StateHasChanged();

        try
        {
            using HttpClient client = HttpFactory.CreateClient();

            PostWifiRequestRecord request = new()
            {
                SSID = Ssid,
                Password = Password
            };

            byte[] body = request.Serialize();

            using ByteArrayContent content = new(body);

            content.Headers.ContentType =
                new("application/octet-stream");

            HttpResponseMessage response =
                await client.PostAsync(PostWifiUrl, content);

            byte[] data =
                await response.Content.ReadAsByteArrayAsync();

            PostWifiResponseRecord result = new();

            result.Deserialize(data);

            PostResult = result;

            if(result.Success)
            {
                WifiStatus = new GetWifiStatusResponseRecord
                {
                    Connected = result.Success,
                    SSID = Ssid
                };
            }
        }
        catch
        {
            DeviceReachable = false;
            PostResult = null;
        }

        PostingWifi = false;
    }
}